import std.libc;
import std.mem;

pub fn c_alloc_impl(ctx: *void, size: i64) -> *void {
    return std.libc.malloc(size);
}

pub fn c_free_impl(ctx: *void, ptr: *void) -> void {
    std.libc.free(ptr);
}

pub const c_allocator: std.mem.Allocator = std.mem.Allocator {
    ctx: 0 as *void,
    alloc: c_alloc_impl,
    free: c_free_impl
};
