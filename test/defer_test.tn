// Simple defer test
fn test_defer() -> i32 {
    var x: i32 = 0;
    defer { x = 1; }
    return x;
}

// Function should return 0, then x becomes 1
// This is hard to test in the current harness directly without running code
// but we can at least ensure it parses and compiles.
fn main() -> i32 {
    return test_defer();
}
