fn main() {
    print("Start loop\n");
    
    i: i64 = 0;
    while i < 3 {
        defer print("Deferred in loop iteration\n");
        print("Loop body\n");
        
        if i == 1 {
            print("Breaking early!\n");
            break;
        }
        
        i = i + 1;
    }
    
    print("End program\n");
}